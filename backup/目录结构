mini_renderer/  // 项目根目录，组织整个渲染器源码与输出
├── CMakeLists.txt  // CMake 构建脚本，定义编译目标与源文件列表
├── include/  // 头文件目录，放接口声明与内联实现
│   ├── core/  // 基础数学、随机数、统计等通用组件
│   │   ├── vec3.h  // 三维向量、颜色、点的基础数学类型
│   │   ├── ray.h  // 射线类型，表示起点与方向
│   │   ├── random.h  // 随机采样工具，如均匀采样和余弦采样
│   │   ├── frame.h  // 局部坐标系 Frame，用于把采样方向转到世界坐标
│   │   ├── aabb.h  // 轴对齐包围盒 AABB 及求交测试
│   │   └── stats.h  // 渲染统计计数器的声明
│   │
│   ├── geometry/  // 场景几何体与求交接口
│   │   ├── hit.h  // HitRecord 命中记录，保存交点、法线、材质等信息
│   │   ├── hittable.h  // 可求交物体的抽象基类接口
│   │   ├── sphere.h  // 球体几何的声明
│   │   ├── plane.h  // 平面几何的声明
│   │   ├── quad.h  // 矩形面片几何的声明
│   │   ├── triangle.h  // 三角形几何的声明
│   │   └── bvh.h  // BVH 加速结构节点的声明
│   │
│   ├── material/  // 材质系统接口
│   │   └── material.h  // 材质基类、Lambertian 和 DiffuseLight 的声明
│   │
│   ├── light/  // 显式光源采样接口
│   │   └── light.h  // 光源基类、球光源和矩形光源的声明
│   │
│   ├── render/  // 渲染流程相关接口
│   │   ├── camera.h  // 相机声明，负责生成主光线
│   │   ├── film.h  // 图像缓存声明，负责存像素与输出文件
│   │   ├── renderer.h  // 渲染器声明，负责路径追踪主循环
│   │   └── scene.h  // 场景声明，管理物体、光源和 BVH
│   │
│   └── image/  // 图像格式辅助工具
│       └── image.h  // PNG 输出辅助函数
│
├── src/  // 源文件目录，放各模块实现
│   ├── core/  // 基础模块实现
│   │   └── stats.cpp  // 渲染统计计数器的定义
│   │
│   ├── geometry/  // 几何体与 BVH 的实现
│   │   ├── sphere.cpp  // 球体求交与包围盒实现
│   │   ├── plane.cpp  // 平面求交实现
│   │   ├── quad.cpp  // 矩形面片求交与包围盒实现
│   │   ├── triangle.cpp  // 三角形求交与包围盒实现
│   │   └── bvh.cpp  // BVH 构建与遍历求交实现
│   │
│   ├── material/  // 材质模块实现
│   │   └── material.cpp  // 材质评估、采样和发光实现
│   │
│   ├── light/  // 光源模块实现
│   │   └── light.cpp  // 光源采样与 pdf 计算实现
│   │
│   ├── render/  // 渲染流程实现
│   │   ├── camera.cpp  // 相机参数初始化与生成射线实现
│   │   ├── film.cpp  // 图像缓存写入与 PPM 保存实现
│   │   ├── renderer.cpp  // 路径追踪、直接光估计和整幅图渲染实现
│   │   └── scene.cpp  // 场景增删、BVH 构建和场景求交实现
│   │
│   └── main.cpp  // 程序入口，搭建场景并启动渲染
│
├── backup/  // 备份与结构说明目录
│   ├── main_quadlight_scene.cpp  // 旧场景示例
│   └── 目录结构  // 当前项目目录结构说明文档
│
└── output/  // 渲染输出目录，保存生成的图像文件